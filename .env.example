###############################################################################
# dnstt-kit — فایل نمونهٔ متغیرهای محیطی
###############################################################################
#
# این فایل را کپی کن به `.env` (همان پوشه) و مقدارها را عوض کن:
#
#   Windows (PowerShell):
#     Copy-Item .env.example .env
#     notepad .env
#
#   Linux / macOS / Termux:
#     cp .env.example .env
#     nano .env
#
# نکته‌های مهم:
#   1) `.env` در gitignore است — رمز/کانفیگ واقعی را commit نکن.
#   2) `dns-cli` موقع اجرا این فایل را خودکار می‌خواند (اگر باشد).
#   3) اگر همان متغیر را در سیستم عامل هم ست کرده باشی، مقدار OS اولویت دارد.
#   4) خطوطی که با # شروع می‌شوند توضیح‌اند و اجرا نمی‌شوند.
#   5) مقدارهای زیر MOCK / مثال‌اند — برای e2e واقعی slipnet کانفیگ خودت را بگذار.
#
# مستند کامل: docs/ENV.md
#
###############################################################################


# -----------------------------------------------------------------------------
# DNS_CLI_WORK_DIR
# -----------------------------------------------------------------------------
# پوشهٔ ریشهٔ پروژه (جایی که config/ و testdata/ و runs/ هستند).
# اگر خالی باشد: همان پوشه‌ای که از آن dns-cli را زدی، یا فلگ --work-dir.
#
# مثال Windows:
#   DNS_CLI_WORK_DIR=C:\Users\You\Desktop\...\saaboon\dnstt-kit
# مثال Linux:
#   DNS_CLI_WORK_DIR=/home/you/saaboon/dnstt-kit
#
# برای شروع معمولاً لازم نیست — از داخل همان پوشه اجرا کن:
#   cd dnstt-kit
#   dns-cli doctor
#
# DNS_CLI_WORK_DIR=


# -----------------------------------------------------------------------------
# SLIPNET_PATH
# -----------------------------------------------------------------------------
# مسیر مستقیم باینری slipnet (اختیاری).
# اگر خالی باشد، dns-cli به ترتیب این‌ها را می‌گردد:
#   1) فلگ --slipnet / --path
#   2) همین متغیر SLIPNET_PATH
#   3) کنار خود dns-cli.exe
#   4) vendor/slipnet/<سیستم-عامل>/slipnet(.exe)
#
# مثال Windows:
#   SLIPNET_PATH=C:\...\dnstt-kit\vendor\slipnet\windows-x86_64\slipnet.exe
# مثال Linux:
#   SLIPNET_PATH=/opt/dnstt-kit/vendor/slipnet/linux-x86_64/slipnet
#
# SLIPNET_PATH=


# -----------------------------------------------------------------------------
# SLIPNET_CONFIG
# -----------------------------------------------------------------------------
# کانفیگ تونل برای مرحلهٔ e2e واقعی slipnet داخل pipeline.
# فرمت: یک لینک slipnet://... (base64 از فیلدهای | جدا)
#
# بدون این مقدار (و بدون --slipnet-config):
#   pipeline همچنان scan + generate را انجام می‌دهد،
#   ولی مرحلهٔ e2e slipnet را با هشدار رد می‌کند.
#
# جایگزین بدون کانفیگ واقعی:
#   dns-cli slipnet probe
#   dns-cli pipeline run ... --slipnet-probe
#
# --- نمونهٔ MOCK (عمداً دامنه/رمز جعلی — برای یادگیری فرمت، نه اتصال واقعی) ---
# اگر می‌خواهی فقط ببینی متغیر لود می‌شود، خط زیر را از حالت کامنت دربیاور:
#
# SLIPNET_CONFIG=slipnet:
#
# --- کانفیگ واقعی خودت (جایگزین MOCK) ---
# از خروجی generate یا پنل سرورت کپی کن:
#   dns-cli generate slipnet-uri --profile mame --resolvers testdata/resolvers_sample.json
# سپس:
#   SLIPNET_CONFIG=slipnet://....لینک_واقعی_خودت....
#
SLIPNET_CONFIG=


# -----------------------------------------------------------------------------
# DNS_CLI_BIND
# -----------------------------------------------------------------------------
# آدرس گوش‌دادن پنل وب وقتی `dns-cli serve` را بدون --bind بزنی.
# پیش‌فرض کد: 127.0.0.1:8787
#
# مثال:
#   DNS_CLI_BIND=127.0.0.1:8787
#   DNS_CLI_BIND=0.0.0.0:8787
#     (فقط اگر عمداً می‌خواهی از شبکهٔ محلی دیده شود — روی اینترنت عمومی نگذار)
#
# DNS_CLI_BIND=127.0.0.1:8787


# -----------------------------------------------------------------------------
# DNS_CLI_WEB_TOKEN
# -----------------------------------------------------------------------------
# اگر ست شود، همهٔ /api/* نیاز به هدر دارند:
#   Authorization: Bearer <token>
#   یا X-DNS-CLI-Token: <token>
# در UI زبانهٔ گزینه‌ها → فیلد توکن (sessionStorage).
# روی bind غیر-localhost قویاً توصیه می‌شود.
#
# DNS_CLI_WEB_TOKEN=change-me-to-a-long-random-string


# -----------------------------------------------------------------------------
# چک سریع بعد از ساخت .env
# -----------------------------------------------------------------------------
#   .\dns-cli.cmd info
#   .\dns-cli.cmd doctor
#   docs/ENV.md · docs/SECURITY_WEB.md · docs/MEMORY.md · docs/DOCKER.md
#
